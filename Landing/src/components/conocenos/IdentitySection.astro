---
import SectionTitle from '../ui/SectionTitle.astro';

/**
 * @component IdentitySection
 * @description Sección de "Identidad" que muestra la misión/visión de la empresa y el logo flotante.
 * Coloca énfasis en la transparencia y evolución de la empresa.
 */
---

<section class="identity-section reveal">
  <div class="container">
    <div class="identity-grid">
      <div class="identity-text">
        <SectionTitle 
          title="Transparencia como primer principio." 
          label="IDENTIDAD"
        />
        
        <p>
          Pro-Finance nació con la visión de democratizar el acceso a los
          mercados globales a través de tecnología de vanguardia y un
          compromiso inquebrantable con la claridad absoluta.
        </p>
        <p>
          A lo largo de más de 15 años, hemos evolucionado para convertirnos
          en un referente de innovación financiera, eliminando los
          conflictos de interés y priorizando el éxito de nuestros socios.
        </p>
      </div>
      
      <div class="identity-visual">
        <div class="logo-container">
          <img
            src="/LOGOSINFONDO-35.png"
            alt="Logo Pro-Finance"
            class="floating-logo"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .container {
    width: 100%;
    max-width: 1200px; /* Ajusta según el ancho de tu Header */
    margin: 0 auto;    /* Centra el bloque horizontalmente */
    padding: 0 2rem;   /* Evita que el texto toque los bordes en móviles */
  }

  .identity-section {
    padding: 80px 0;
    overflow: hidden; /* Evita scrolls horizontales por la animación */
  }

  .identity-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .identity-text p {
    color: #a0a0a0; /* text-gray */
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }

  /* LOGO CONTROLADO */
  .logo-container {
    width: 280px;
    height: 280px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    margin: 0 auto;
  }

  .floating-logo {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 15px rgba(0, 0, 0, 0.5));
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  @media (max-width: 992px) {
    .identity-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .logo-container {
      width: 220px;
      height: 220px;
    }
  }

  /* Reveal Animation Helpers (handled globally or by parent, but basic transition here for scoped usage) */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: 0.8s ease-out;
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>
