---
import SectionTitle from '../ui/SectionTitle.astro';

/**
 * @component TechSection
 * @description Sección de Infraestructura. Muestra una tarjeta grande con imagen y características clave (baja latencia, seguridad).
 * Utiliza un diseño de grilla dividida (texto + imagen).
 */
---

<section class="tech-section reveal">
  <div class="container">
    <div class="tech-card-large">
      <div class="tech-content">
        <SectionTitle 
          title="Potencia de ejecución institucional." 
          label="INFRAESTRUCTURA"
          darkLabel={true}
        >
          <!-- El SectionTitle no tenía slot, pero podemos añadir contenido debajo o usarlo así -->
        </SectionTitle>

        <div class="tech-features">
          <div class="feat">
            <span class="feat-icon">⚡</span>
            <div>
              <h5>Baja Latencia</h5>
              <p>
                Servidores en Equinix NY4 para ejecuciones en milisegundos.
              </p>
            </div>
          </div>
          <div class="feat">
            <span class="feat-icon">🛡️</span>
            <div>
              <h5>Seguridad Tier-1</h5>
              <p>
                Fondos custodiados en cuentas segregadas de bancos globales.
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="tech-image">
        <!-- Usamos una imagen real o placeholder si no existe la definida -->
        <img src="/tu-foto-hero.jpg" alt="Tecnología Pro-Finance" loading="lazy"/>
      </div>
    </div>
  </div>
</section>

<style>
  .tech-section {
    padding: 80px 0;
  }

  .tech-card-large {
    background: white;
    border-radius: 30px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    min-height: 450px;
    color: #000;
  }

  .tech-content {
    padding: 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .tech-features {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  .feat {
    display: flex;
    gap: 1.5rem;
  }

  .feat-icon {
    font-size: 1.5rem;
  }

  .feat h5 {
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
    font-weight: 700;
    font-family: var(--font-primary, sans-serif);
  }

  .feat p {
    color: #555;
    font-size: 0.95rem;
  }

  .tech-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 992px) {
    .tech-card-large {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .tech-image {
      order: -1;
      height: 300px;
    }
    .tech-content {
      align-items: center; /* Centrar items */
    }
    .feat {
      flex-direction: column;
      align-items: center;
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: 0.8s ease-out;
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>
