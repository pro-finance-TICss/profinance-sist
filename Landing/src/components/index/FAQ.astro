---
import GoldButton from '../ui/GoldButton.astro';

/**
 * @component FAQ
 * @description Sección de Preguntas Frecuentes con acordeón y formulario de contacto.
 * Incluye validación del lado del cliente para el formulario.
 */
---

<section id="faq" class="faq-section">
  <div class="container">
    <h2 class="section-title">
      Preguntas <span class="text-gradient-gold">Frecuentes</span>
    </h2>

    <div class="faq-layout">
      <!-- Lista de Preguntas -->
      <div class="faq-list">
        <div class="faq-item">
          <details>
            <summary>¿Cómo puedo abrir una cuenta?</summary>
            <div class="faq-content">
              <p>
                Es muy sencillo. Solo necesitas hacer clic en "Hazte cliente",
                llenar el formulario con tus datos básicos y verificar tu
                identidad. El proceso toma menos de 10 minutos.
              </p>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details>
            <summary>¿Cuál es el monto mínimo de inversión?</summary>
            <div class="faq-content">
              <p>
                Puedes comenzar a invertir desde $100 USD. Ofrecemos diferentes
                planes que se adaptan a tu capacidad de inversión y objetivos
                financieros.
              </p>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details>
            <summary>¿Mis datos están seguros?</summary>
            <div class="faq-content">
              <p>
                Absolutamente. Utilizamos encriptación de nivel bancario y
                cumplimos con todas las normativas de protección de datos para
                garantizar tu seguridad y privacidad.
              </p>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details>
            <summary>¿Puedo retirar mi dinero en cualquier momento?</summary>
            <div class="faq-content">
              <p>
                Sí, ofrecemos liquidez semanal o mensual dependiendo del plan
                que elijas. No hay plazos forzosos ocultos.
              </p>
            </div>
          </details>
        </div>
      </div>

      <!-- Tarjeta de Contacto -->
      <div class="contact-card">
        <h3>¿Necesitas más ayuda?</h3>
        <p>Déjanos un mensaje y te contactaremos.</p>
        
        <form class="contact-form" id="contactForm" novalidate>
          <div class="form-group">
            <label for="contact-name" class="sr-only">Nombre completo</label>
            <input 
              type="text" 
              id="contact-name" 
              name="name" 
              placeholder="Nombre completo" 
              required 
              minlength="2"
              pattern="^[a-zA-ZñÑáéíóúÁÉÍÓÚ\s]+$"
            />
            <span class="error-msg">Ingresa un nombre válido.</span>
          </div>
          
          <div class="form-group">
             <label for="contact-email" class="sr-only">Correo electrónico</label>
            <input 
              type="email" 
              id="contact-email" 
              name="email" 
              placeholder="Correo electrónico" 
              required 
            />
             <span class="error-msg">Ingresa un correo válido.</span>
          </div>
          
          <div class="form-group">
             <label for="contact-message" class="sr-only">Mensaje</label>
            <textarea 
              id="contact-message" 
              name="message" 
              placeholder="Tu mensaje" 
              rows="4" 
              required
              minlength="10"
              maxlength="500"
            ></textarea>
             <span class="error-msg">El mensaje debe tener al menos 10 caracteres.</span>
          </div>
          
          <GoldButton type="submit" class="submit-btn" style="width: 100%;">
            Enviar Mensaje
          </GoldButton>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 6rem 0;
    position: relative;
    z-index: 10;
  }

  .container {
    width: 90%;
    max-width: 1400px; 
    margin: 0 auto;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    text-align: center;
    font-family: var(--font-primary, sans-serif);
  }

  .faq-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 992px) {
    .faq-layout {
      grid-template-columns: 2fr 1fr;
    }
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  details {
    cursor: pointer;
    padding: 1rem 0;
    transition: all 0.3s ease;
  }

  details[open] {
    padding-bottom: 2rem;
  }

  summary {
    font-family: var(--font-secondary);
    font-size: 1.2rem;
    font-weight: bold;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: "+";
    font-size: 1.5rem;
    color: var(--color-gold-start, #bd8e48);
    transition: transform 0.3s;
  }

  details[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-content p {
    margin-top: 1rem;
    color: #ccc;
    font-size: 1rem;
    line-height: 1.6;
  }

  /* Contact Card Styles */
  .contact-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 20px;
    padding: 2rem;
    backdrop-filter: blur(10px);
    align-self: flex-start;
  }

  .contact-card h3 {
    color: var(--color-gold-start, #bd8e48);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-primary, sans-serif);
  }

  .contact-card p {
    color: #ccc;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    position: relative;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem;
    color: white; /* var(--color-white) */
    font-family: var(--font-secondary, sans-serif);
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-gold-start, #bd8e48);
  }

  .form-group input:invalid:not(:placeholder-shown),
  .form-group textarea:invalid:not(:placeholder-shown) {
     border-color: #ff6b6b;
  }

  .error-msg {
    display: none;
    color: #ff6b6b;
    font-size: 0.8rem;
    margin-top: 0.25rem;
  }

  .form-group input:invalid:not(:placeholder-shown) + .error-msg,
  .form-group textarea:invalid:not(:placeholder-shown) + .error-msg {
    display: block;
  }

  .form-group textarea {
    resize: vertical;
  }
  
  /* Helper sr-only (Screen Reader Only) - si no está en global.css */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>

<script>
  // Simple Client-Side Validation Script
  const form = document.getElementById('contactForm') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Check HTML5 validity
      if (!form.checkValidity()) {
        // Find first invalid input and focus
        const firstInvalid = form.querySelector(':invalid') as HTMLElement;
        if (firstInvalid) firstInvalid.focus();
        return;
      }
      
      // Sanitización básica (Solo demostrativa, el backend debe hacer la real)
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      // sanitize strings (simple replace < >)
      const cleanData: any = {};
      for (const [key, val] of Object.entries(data)) {
        if (typeof val === 'string') {
          cleanData[key] = val.replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }
      }

      console.log("Datos seguros listos para enviar:", cleanData);
      alert("¡Mensaje enviado correctamente! (Simulación)");
      form.reset();
    });
  }
</script>
