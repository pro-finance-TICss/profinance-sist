---
---
<header class="header">
  <div class="header-container">
    <a href="/#hero" class="logo-container">
      <img 
        src="/logo2temp.png" 
        alt="Pro-Finance logo"
        class="logo-img"
      />
      <span class="brand-name text-gradient-gold">PRO-FINANCE</span>
    </a>
    
    <nav class="nav-links">
      <a href="/#hero" class="nav-link">Inicio</a>
      <a href="/conocenos" class="nav-link">Conócenos</a>
      <a href="/#beneficios" class="nav-link">Beneficios</a>
      <a href="/#faq" class="nav-link">FAQ y Contacto</a>
    </nav>
    
    <div class="auth-buttons">
  <a 
    href="https://app.profinance.com.co"
    class="btn btn-primary small"
    onclick="window.location.href='https://app.profinance.com.co'; return false;"
  >
    <span class="btn-text">INGRESAR</span>
  </a>
</div>
</header>

<style>
  .header {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 1600px;
    z-index: 100;
    
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    backdrop-filter: blur(5px);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
  }

  .logo-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }

  .logo-img {
    width: 60px;
    height: auto;
    max-height: 40px;
    object-fit: contain;
    display: block;
  }

  .brand-name {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    -webkit-text-fill-color: transparent;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-secondary);
    font-size: 1.1rem;
    color: var(--color-white);
  }

  .auth-buttons {
    display: flex;
    gap: 1rem;
  }

  .small {
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
  }
  
  .btn-primary {
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }

    .nav-links {
      gap: 1rem;
      width: 100%;
      justify-content: center;
      flex-wrap: wrap; 
    }
    
    .auth-buttons {
      width: 100%;
      justify-content: center;
    }
  }
</style>
