---
---
<section class="hero">
  <div class="hero-container">
    <!-- Logo Superior -->
    <img src="/Background-recortado.png" alt="Pro-Finance Logo" class="hero-logo-top" />

    <!-- Título Principal -->
    <div class="hero-content">
      <h1>
        EMPODERANDO TU <br />
        <span class="text-gradient-gold">FUTURO FINANCIERO</span>
      </h1>
      <p class="hero-subtitle">
        Somos el vínculo entre el capital y el crecimiento. <br />
        construyendo confianza y resultados reales.
      </p>

      <!-- Botones -->
      <div class="hero-actions">
        <a href="#operar" class="btn btn-primary">
          <span class="btn-text">COMIENZA A OPERAR</span>
        </a>
        <a href="/conocenos" class="btn btn-outline">
          NUESTRA HISTORIA
        </a>
      </div>
    </div>

    <!-- Barra de Estadísticas -->
    <div class="hero-stats">
      <div class="stat-item">
        <h2 class="stat-number" data-target="15" data-suffix="+">0</h2>
        <p class="stat-label">AÑOS DE EXPERIENCIA</p>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <h2 class="stat-number" data-target="9.2" data-prefix="$" data-suffix="B" data-decimals="1">0</h2>
        <p class="stat-label">VOLUMEN DIARIO</p>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <h2 class="stat-number" data-target="110" data-suffix="k+">0</h2>
        <p class="stat-label">CLIENTES ACTIVOS</p>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <h2 class="stat-number" data-target="0.0" data-suffix="ms" data-decimals="1">0</h2>
        <p class="stat-label">VELOCIDAD EJECUCIÓN</p>
      </div>
    </div>
  </div>
</section>

<script>
  function animateCounters() {
    const stats = document.querySelectorAll('.stat-number');
    
    stats.forEach(stat => {
      const target = parseFloat(stat.getAttribute('data-target') || '0');
      const prefix = stat.getAttribute('data-prefix') || '';
      const suffix = stat.getAttribute('data-suffix') || '';
      const decimals = parseInt(stat.getAttribute('data-decimals') || '0');
      const duration = 2500; // 2 segundos
      const stepTime = 15;
      const steps = duration / stepTime;
      const increment = target / steps;
      let current = 0;

      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          stat.textContent = prefix + target.toFixed(decimals) + suffix;
          clearInterval(timer);
        } else {
          stat.textContent = prefix + current.toFixed(decimals) + suffix;
        }
      }, stepTime);
    });
  }

  // Iniciar animación cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', animateCounters);
  // Re-iniciar si se usa Astro view transitions
  document.addEventListener('astro:page-load', animateCounters);
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 20px 60px;
    background-color: var(--color-black);
    overflow: hidden;
  }

  /* Fondo con patrón de puntos y gradiente radial */
  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
      radial-gradient(circle at 50% 50%, rgba(189, 142, 72, 0.05) 0%, transparent 70%),
      radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 100% 100%, 30px 30px;
    pointer-events: none;
  }

  .hero-container {
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    z-index: 2;
  }

  .hero-logo-top {
    height: 240px; /* Un poco grande para que destaque solo */
    width: auto;
    object-fit: contain;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-white);
    letter-spacing: -1px;
    text-transform: uppercase;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #a0a0a0; /* Gris sutil CHECAR PALETA COLORES*/
    max-width: 800px;
    margin: 0 auto 3rem;
    line-height: 1.6;
    font-family: var(--font-secondary);
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 3.5rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    border: 1px solid var(--color-gold-start);
    color: var(--color-gold-end);
    font-family: var(--font-primary);
    font-size: 0.9rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    background: transparent;
  }

  .btn-outline:hover {
    background: rgba(189, 142, 72, 0.1);
    transform: translateY(-2px);
  }

  /* Sobrescribir estilos de btn-primary para este contexto si es necesario */
  :global(.btn-primary) {
    border-radius: 8px !important;
    padding: 0.75rem 2rem !important;
  }

  .hero-stats {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 1000px;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 2.5rem;
    color: var(--color-gold-end);
    font-family: var(--font-primary);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: #7c7c7c;
    letter-spacing: 1px;
    font-family: var(--font-secondary);
    font-weight: bold;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 768px) {
    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }

    .hero-stats {
      flex-direction: column;
      gap: 2rem;
    }

    .stat-divider {
      display: none;
    }

    h1 {
      font-size: 2.5rem;
    }
  }
</style>

