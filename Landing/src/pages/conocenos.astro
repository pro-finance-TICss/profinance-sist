---
import Layout from "../layouts/Layout.astro";
import Header from '../components/index/Header.astro';
import Footer from '../components/index/Footer.astro';
import SectionTitle from "../components/ui/SectionTitle.astro";

// Secciones Refactorizadas
import IdentitySection from "../components/conocenos/IdentitySection.astro";
import ValuesSection from "../components/conocenos/ValuesSection.astro";
import TechSection from "../components/conocenos/TechSection.astro";
import FlowSection from "../components/conocenos/FlowSection.astro";
import SupportSection from "../components/conocenos/SupportSection.astro";

/**
 * @page Conocenos
 * @description Página "Sobre Nosotros" de Pro-Finance.
 * Estructura modularizada para facilitar mantenimiento.
 */
---

<Layout title="Conócenos | Pro-Finance">
  <Header />

  <main class="about-page">
    <div class="bg-gradient-soft"></div>

    <!-- Hero Section (Específico de esta página) -->
    <section class="hero-clean reveal">
      <div class="container">
        <div class="hero-wrapper">
          <SectionTitle 
            as="h1"
            title="Construyendo el futuro de la gestión de capital."
            highlight="gestión de capital."
            label="NUESTRA INSTITUCIÓN"
            align="left"
          >
             <p class="hero-subtext">
              Desde 2010, Pro-Finance fusiona la ingeniería financiera con la
              ética tecnológica para ofrecer un ecosistema de inversión
              transparente y global.
            </p>
          </SectionTitle>
        </div>
      </div>
    </section>

    <IdentitySection />

    <ValuesSection />

    <TechSection />

    <FlowSection />

    <SupportSection />

    <Footer />
  </main>
</Layout>

<style>
  :root {
    --bg-black: #050505;
    --card-dark: #0f0f0f;
    --gold: #bd8e48;
    --text-gray: #a0a0a0;
  }

  .about-page {
    background: var(--bg-black);
    color: white; /* var(--color-white) */
    overflow-x: hidden;
    min-height: 100vh;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Background Glow */
  .bg-gradient-soft {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at 80% 20%,
      rgba(189, 142, 72, 0.03) 0%,
      transparent 50%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Hero Section Styles */
  .hero-clean {
    padding: 140px 0 80px;
    text-align: center; /* Override alignment inside hero if needed, but SectionTitle handles it */
  }

  .hero-wrapper {
    text-align: left; /* Volver a alinear a la izquierda para el SectionTitle si align='left' */
  }

  .hero-clean :global(.display-title) {
    font-size: clamp(2.5rem, 6vw, 4rem); /* Override size for Hero H1 */
    font-weight: 700;
    margin: 2rem 0;
    line-height: 1.1;
  }

  .hero-subtext {
    max-width: 650px;
    /* margin: 0 auto;  Si queremos centrado, pero align="left" arriba */
    color: var(--text-gray);
    font-size: 1.15rem;
    line-height: 1.6;
    margin-top: 1.5rem;
  }

  /* Reveal Animation Global Helper 
     (Se asegura que todos los componentes que usen .reveal funcionen en este contexto)
  */
  :global(.reveal) {
    opacity: 0;
    transform: translateY(30px);
    transition: 0.8s ease-out;
  }
  :global(.reveal.active) {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Observer para animaciones de entrada
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("active");
      });
    },
    { threshold: 0.1 },
  );
  
  // Observamos todo elemento con clase .reveal (incluyendo los dentro de componentes hijos)
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>