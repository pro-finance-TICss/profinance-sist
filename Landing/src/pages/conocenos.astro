---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Nuestra Institución | Pro-Finance">
  <Header />

  <main class="institutional-page">
    <div class="watermark-bg">
      <img src="/LOGOSINFONDO-35.png" alt="" aria-hidden="true" />
    </div>

    <div class="black-zone">
      <section class="hero-section">
        <div class="container">
          <div class="hero-split reveal">
            <div class="hero-inner">
              <span class="gold-tag">SOBRE NOSOTROS</span>
              <h1 class="text-gradient-gold">NUESTRA <br /> HISTORIA</h1>
              <div class="accent-line"></div>
              <p class="hero-description">
                Innovación y confianza en el mundo financiero desde 2010.
                Construyendo el puente entre el capital y el éxito global.
              </p>
            </div>
            <div class="hero-image-container">
              <img
                src="/tu-foto-hero.jpg"
                alt="Institución Pro-Finance"
                class="hero-side-img"
              />
            </div>
          </div>
        </div>
      </section>

      <section class="story-section">
        <div class="container">
          <div class="story-grid">
            <div class="text-side reveal">
              <h2 class="section-title">SOBRE PRO-FINANCE</h2>
              <div class="paragraphs">
                <p>
                  Pro-Finance nació con la visión de democratizar el acceso a
                  los mercados globales a través de tecnología de vanguardia y
                  un compromiso inquebrantable con la transparencia.
                </p>
                <p>
                  A lo largo de más de 15 años, hemos evolucionado para
                  convertirnos en un referente de innovación financiera.
                </p>
              </div>
            </div>
            <div class="image-side reveal">
              <div class="logo-emblem">
                <img src="/LOGOSINFONDO-35.png" alt="Emblema Pro-Finance" />
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="mid-zone">
      <section class="impact-section reveal">
        <div class="container">
          <div class="white-card">
            <div class="card-photo">
              <img src="/tu-foto-aqui.jpg" alt="Gestión de Capital" />
              <div class="photo-label">VISIÓN GLOBAL</div>
            </div>
            <div class="card-body">
              <h2 class="dark-title">GESTIÓN DE CAPITAL INTELIGENTE</h2>
              <p class="dark-p">
                Nuestra infraestructura está diseñada para soportar las
                ambiciones de los socios más exigentes, combinando seguridad de
                alto nivel con una ejecución humana y transparente.
              </p>
              <div class="dark-separator"></div>
            </div>
          </div>
        </div>
      </section>

      <section class="trust-section reveal">
        <div class="container">
          <div class="trust-wrapper">
            <div class="trust-header">
              <h2 class="gold-h2">POR QUÉ ELEGIR PRO-FINANCE</h2>
              <p>
                No somos solo una plataforma; somos tu aliado estratégico.
                Mientras otros compiten por precio, nosotros competimos por
                valor, ejecución y confianza.
              </p>
            </div>

            <div class="trust-grid">
              <div class="trust-info">
                <div class="trust-item">
                  <span class="trust-icon">⚡</span>
                  <div>
                    <h3>EJECUCIÓN ULTRA-RÁPIDA</h3>
                    <p>
                      Latencia mínima gracias a nuestros servidores Equinix NY4.
                    </p>
                  </div>
                </div>
                <div class="trust-item">
                  <span class="trust-icon">🛡️</span>
                  <div>
                    <h3>SEGURIDAD DE FONDOS</h3>
                    <p>
                      Tus fondos se mantienen en cuentas fiduciarias segregadas
                      en bancos Tier-1.
                    </p>
                  </div>
                </div>
                <div class="trust-item">
                  <span class="trust-icon">📈</span>
                  <div>
                    <h3>RENDIMIENTOS COMPETITIVOS</h3>
                    <p>
                      Optimización constante de retornos bajo modelos
                      algorítmicos.
                    </p>
                  </div>
                </div>
                <a href="#" class="regulatory-link"
                  >VER LICENCIAS Y REGULACIONES →</a
                >
              </div>

              <div class="support-card">
                <div class="support-inner">
                  <span class="support-time">24/7</span>
                  <span class="support-label">SOPORTE GLOBAL</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="gold-footer-section">
      <Footer />
    </div>
  </main>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("active");
      });
    },
    { threshold: 0.1 },
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

<style>
  /* --- BASE Y TRANSICIONES --- */
  .institutional-page {
    background-color: var(--color-black);
    color: var(--color-white);
    overflow-x: hidden;
    position: relative;
  }

  /* Secciones con cambio de tono */
  .black-zone {
    background-color: #000;
    position: relative;
    z-index: 1;
  }
  .mid-zone {
    background-color: #0a0a0a;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.02);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* LOGO DE FONDO */
  .watermark-bg {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60vw;
    max-width: 600px;
    z-index: 0;
    opacity: 0.08;
    pointer-events: none;
    filter: sepia(1) saturate(4) hue-rotate(10deg) brightness(0.7);
  }
  .watermark-bg img {
    width: 100%;
    height: auto;
  }

  /* HERO MODIFICADO CON IMAGEN LATERAL */
  .hero-section {
    padding: 180px 0 80px;
  }
  .hero-split {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-image-container {
    width: 100%;
    aspect-ratio: 4/3;
    background: #111;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(189, 142, 72, 0.1);
  }
  .hero-side-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gold-tag {
    color: var(--color-gold-start);
    letter-spacing: 4px;
    font-weight: bold;
    font-size: 0.8rem;
  }
  .hero-section h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1.1;
    margin: 1rem 0;
  }
  .accent-line {
    width: 60px;
    height: 4px;
    background: var(--color-gold-start);
    margin-bottom: 2rem;
  }
  .hero-description {
    font-size: 1.2rem;
    color: #aaa;
    max-width: 550px;
    line-height: 1.6;
  }

  /* STORY SECTION */
  .story-section {
    padding: 80px 0;
  }
  .story-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 5rem;
    align-items: center;
  }
  .section-title {
    font-size: 2.2rem;
    color: var(--color-gold-end);
    margin-bottom: 2rem;
  }
  .paragraphs p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-complementary-grey);
    margin-bottom: 1.5rem;
  }

  .logo-emblem {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 25px;
    backdrop-filter: blur(10px);
  }
  .logo-emblem img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 15px var(--color-gold-dim));
  }

  /* SECCIÓN BLANCA */
  .impact-section {
    padding: 80px 0;
  }
  .white-card {
    background: #fff;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
  }
  .card-photo {
    position: relative;
    min-height: 400px;
    background: #f0f0f0;
  }
  .card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .photo-label {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--color-gold-start);
    color: #000;
    padding: 5px 15px;
    font-weight: bold;
    font-size: 0.8rem;
  }
  .card-body {
    padding: 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .dark-title {
    color: #000;
    font-family: var(--font-primary);
    font-size: 2.3rem;
    margin-bottom: 1.5rem;
  }
  .dark-p {
    color: #444;
    font-size: 1.1rem;
    line-height: 1.7;
  }
  .dark-separator {
    width: 40px;
    height: 3px;
    background: var(--color-gold-start);
    margin-top: 2rem;
  }

  /* CONFIABILIDAD */
  .trust-section {
    padding: 120px 0;
  }
  .trust-wrapper {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 5rem;
    border-radius: 30px;
  }
  .gold-h2 {
    color: var(--color-gold-end);
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }
  .trust-header p {
    color: #888;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 3rem;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: 1.5fr 0.5fr;
    gap: 4rem;
    align-items: flex-start;
  }
  .trust-item {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .trust-icon {
    font-size: 1.8rem;
    color: var(--color-gold-start);
  }
  .trust-item h3 {
    font-size: 1rem;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }
  .trust-item p {
    color: #777;
    font-size: 0.95rem;
  }
  .regulatory-link {
    color: var(--color-gold-start);
    font-weight: bold;
    text-decoration: none;
    border-bottom: 1px solid;
    padding-bottom: 5px;
    transition: 0.3s;
  }
  .regulatory-link:hover {
    color: #fff;
    border-color: #fff;
  }
  .support-card {
    background: rgba(189, 142, 72, 0.1);
    border: 1px solid var(--color-gold-dim);
    padding: 2.5rem;
    border-radius: 20px;
    text-align: center;
  }
  .support-time {
    display: block;
    font-family: var(--font-primary);
    font-size: 3rem;
    color: var(--color-gold-start);
  }
  .support-label {
    font-size: 0.8rem;
    letter-spacing: 2px;
    color: #888;
    font-weight: bold;
  }

  /* FOOTER DORADO SUTIL */
  .gold-footer-section {
    background-color: #000;
    border-top: 1px solid rgba(189, 142, 72, 0.15);
    /* Aplicamos un filtro suave para dar calidez dorada al footer */
    filter: sepia(0.15) saturate(1.1) brightness(0.9);
  }

  @media (max-width: 992px) {
    .hero-split,
    .story-grid,
    .white-card,
    .trust-grid {
      grid-template-columns: 1fr;
    }
    .hero-section {
      text-align: center;
    }
    .accent-line {
      margin: 1rem auto 2rem;
    }
    .watermark-bg {
      width: 80vw;
    }
  }
</style>
