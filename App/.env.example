# ============================================================================
# VARIABLES DE ENTORNO - PRO-FINANCE
# ============================================================================
# Copia este archivo como .env y configura los valores.
# NUNCA commits .env con valores reales a git.
# ============================================================================

# Base de datos SQLite (desarrollo)
DATABASE_URL="file:./dev.db"

# NextAuth.js
# Genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-super-seguro-generado-con-openssl"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# URL PÚBLICA DEL SITIO (OBLIGATORIA EN PRODUCCIÓN)
# ============================================================================
# Usada para generar links de referido correctos. NUNCA debe contener
# "localhost" en producción. Debe ser la URL exacta con la que los usuarios
# acceden a la plataforma (sin trailing slash).
#
# Diferencia con NEXTAUTH_URL:
#   - NEXTAUTH_URL: usada internamente por NextAuth (puede ser diferente)
#   - NEXT_PUBLIC_SITE_URL: URL pública real visible para los usuarios
#
# Ejemplos:
#   Desarrollo: NEXT_PUBLIC_SITE_URL="http://localhost:3000"
#   Producción: NEXT_PUBLIC_SITE_URL="https://app.profinance.com"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# API URL (para llamadas desde el cliente)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Entorno
NODE_ENV="development"

# ============================================================================
# MERCADO PAGO (PAGOS)
# ============================================================================
# Obtén tus credenciales en: https://www.mercadopago.com.co/developers/panel
MERCADOPAGO_ACCESS_TOKEN="TEST-tu_access_token"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="TEST-tu_public_key"

# Webhook secret (X-Signature)
MERCADOPAGO_WEBHOOK_SECRET="tu_webhook_secret"

# ============================================================================
# NOTIFICACIONES
# ============================================================================
# Email del departamento de finanzas para notificaciones de retiro
FINANCE_DEPARTMENT_EMAIL="finance@profinance.com"

# ============================================================================
# ENCRIPTACIÓN (CUENTAS BANCARIAS)
# ============================================================================
# Clave AES-256 de 64 caracteres hexadecimales (32 bytes).
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBLIGATORIA en producción. En desarrollo se usa una clave temporal automática.
ENCRYPTION_KEY="tu_clave_de_64_caracteres_hex"
