# ============================================================================
# VARIABLES DE ENTORNO - PRO-FINANCE
# ============================================================================
# Copia este archivo como .env y configura los valores.
# NUNCA commits .env con valores reales a git.
# ============================================================================

# Base de datos SQLite (desarrollo)
DATABASE_URL="file:./dev.db"

# NextAuth.js
# Genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-super-seguro-generado-con-openssl"
NEXTAUTH_URL="http://localhost:3000"

# API URL (para llamadas desde el cliente)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Entorno
NODE_ENV="development"
